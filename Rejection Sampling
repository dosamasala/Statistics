Estimarea mediei, g1:

```{r}
t1 <- 1.5  #acest numar asigura t1*g1 > f_bar, pentru orice x
medie_g1 <- function(n){
  t <- 1.5
  out <- numeric(n)
  for(i in 1:n){
    k <- 0
    while(k==0){
    X <- gen_g1(1)
    u <- runif(1)
    m <- t*g1(X)*u
    if(X>0){  #pas necesar, deoarece f_bar este definita pe (0, inf)
    if(m <= f_bar(X)){
      out[i] <- X
      k<-1
    }
    }
    }
  }
  m <- mean(out)
  return(m)
}
medie_g1(200000)
```

